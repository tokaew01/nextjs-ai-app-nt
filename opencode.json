{
  "$schema": "https://opencode.ai/config.json",
  "formatter": true,
  "lsp": true,
  "permission": {
    "bash": {
      "git add *": "allow",
      "git commit *": "allow",
      "rm *": "ask"
    }
  },
  "mcp": {
    "next-devtools-mcp": {
      "type": "local",
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true
    }
  }
}
